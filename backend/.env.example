# 数据库连接（异步驱动 asyncpg）
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/rfq_db

# 应用环境
APP_ENV=development

# JWT 密钥（第一阶段未使用，预留）
SECRET_KEY=change-me-in-production

# CORS 允许的前端地址（多个地址用逗号分隔）
ALLOWED_ORIGINS=http://localhost:5173

# 上传文件暂存目录
UPLOAD_DIR=./uploads

# 上传文件大小限制（MB）
MAX_UPLOAD_SIZE_MB=10

# 第一阶段默认上传人（未做登录时使用）
DEFAULT_UPLOAD_USER=demo_user
